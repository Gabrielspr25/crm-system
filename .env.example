# =========================================================================
# .env.example — plantilla de variables de entorno para el backend Node.js
# Copiar a `.env` y completar con valores reales. NO commitear el .env real.
# =========================================================================

# -------- Servidor HTTP --------
PORT=3001
NODE_ENV=development

# -------- Base de datos PROPIA (CRM Pro) --------
# Usada por src/backend/database/db.js
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crm_pro
DB_USER=crm_user
DB_PASSWORD=__CAMBIAR__

# Secreto para firmar JWT de sesion. Usar un string aleatorio largo.
JWT_SECRET=__CAMBIAR_POR_UN_SECRETO_LARGO__

# -------- Base de datos EXTERNA (Tango / POS / ClaroPR) --------
# Usada por src/backend/database/externalPools.js
# Todas las variables son OBLIGATORIAS cuando se usa el pool externo.
# Si algun prefijo no esta seteado, el pool cae al siguiente en el orden
# definido en externalPools.js (TANGO_DB -> POS_DB -> DISCREPANCIAS_DB).
POS_DB_HOST=
POS_DB_PORT=5432
POS_DB_NAME=
POS_DB_USER=
POS_DB_PASSWORD=
POS_DB_SSL=false
POS_DB_SSL_REJECT_UNAUTHORIZED=false
POS_DB_MAX_CONNECTIONS=5
POS_DB_CONNECTION_TIMEOUT_MS=15000
POS_DB_QUERY_TIMEOUT_MS=30000
POS_DB_STATEMENT_TIMEOUT_MS=30000
POS_DB_IDLE_TIMEOUT_MS=30000

# Override opcional para el pool TANGO (si difiere de POS)
# TANGO_DB_HOST=
# TANGO_DB_PORT=5432
# TANGO_DB_NAME=
# TANGO_DB_USER=
# TANGO_DB_PASSWORD=

# Override opcional para el pool de DISCREPANCIAS
# DISCREPANCIAS_DB_HOST=
# DISCREPANCIAS_DB_PORT=5432
# DISCREPANCIAS_DB_NAME=
# DISCREPANCIAS_DB_USER=
# DISCREPANCIAS_DB_PASSWORD=

# -------- SMTP para alertas/notificaciones --------
# (Si el backend Node envia mails; el WAR legacy lee esto desde Configuration.properties)
SMTP_HOST=
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# -------- Azure AD / MSAL (frontend) --------
# Se usan en src/react-app/auth/msalConfig.ts. Exponer solo las que son publicas.
# VITE_MSAL_CLIENT_ID=
# VITE_MSAL_TENANT_ID=
# VITE_MSAL_REDIRECT_URI=
